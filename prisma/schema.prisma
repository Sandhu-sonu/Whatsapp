datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

// Enforced via TypeScript enums:
// - AuditAction: REPORT_REPLAY | REPORT_APPROVED | REPORT_CORRECTED | REPORT_REJECTED | MANUAL_REVIEW | SETTINGS_CHANGED | DATABASE_BACKUP | DATABASE_RESTORE | LOGIN | LOGOUT
// - NotificationType: INFO | SUCCESS | WARNING | ERROR
// - NotificationCategory: OPERATIONAL | TECHNICAL | SYSTEM
// - ValidationStatus: VALID | WARNING | INVALID
// - ParserMode: TEMPLATE | REGEX | KEYWORD | MANUAL
// - IngestionStatus: NEW | PARSED | FAILED | IGNORED
// - SubmissionStatus: SUBMITTED | PENDING
// - MessageType: TEXT | IMAGE | VIDEO | DOCUMENT | AUDIO | VOICE | STICKER | UNKNOWN

model SchemaVersion {
  version   Int      @id
  appliedAt DateTime @default(now())
}

model ParserEngine {
  id         String      @id @default(uuid())
  name       String
  version    String
  build      String
  releasedAt DateTime    @default(now())
  reports    DsdReport[]
}

model District {
  id           String            @id @default(uuid())
  name         String            @unique
  code         String            @unique
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  submissions  DailySubmission[]
  messages     WhatsAppMessage[]
  aliases      DistrictAlias[]
  reports      DsdReport[]
}

model DistrictAlias {
  id         String   @id @default(uuid())
  alias      String   @unique
  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
}

model DailySubmission {
  id          String    @id @default(uuid())
  districtId  String
  district    District  @relation(fields: [districtId], references: [id], onDelete: Cascade)
  reportDate  DateTime  // Normalized date (YYYY-MM-DD at 00:00:00 UTC)
  submittedAt DateTime?
  status      String    @default("PENDING") // SubmissionStatus
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  reports     DsdReport[]

  @@unique([districtId, reportDate])
  @@index([districtId])
  @@index([reportDate])
  @@index([districtId, reportDate])
}

model DsdReport {
  id                   String           @id @default(uuid())
  submissionId         String
  submission           DailySubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  messageId            String?          @unique
  message              WhatsAppMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  districtId           String
  district             District         @relation(fields: [districtId], references: [id], onDelete: Cascade)
  reportDate           DateTime
  receivedAt           DateTime
  previousReportId     String?
  appointmentsBooked   Int
  served               Int
  cancelled            Int
  rescheduled          Int
  validationStatus     String           // ValidationStatus
  validationErrors     String?          // JSON array string
  confidence           Int              // 0 - 100
  isLatest             Boolean          @default(true)
  revisionNumber       Int              @default(0)
  metricsJson          String?          // For future/extra metrics only
  parserMode           String           // ParserMode
  parserEngineId       String?
  parserEngine         ParserEngine?    @relation(fields: [parserEngineId], references: [id], onDelete: SetNull)
  rawExtractedJson     String?          // Preserves original parsed text strings
  processingDurationMs Int?             // Parse execution duration in ms
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  @@unique([submissionId, revisionNumber])
  @@index([reportDate])
  @@index([districtId])
  @@index([submissionId])
  @@index([messageId])
  @@index([isLatest])
  @@index([validationStatus])
  @@index([reportDate, isLatest])
  @@index([districtId, reportDate])
  @@index([submissionId, isLatest])
  @@index([districtId, isLatest])
  @@index([reportDate, validationStatus, isLatest])
}

model WhatsAppMessage {
  id              String    @id @default(uuid())
  whatsappId      String    @unique
  sender          String?
  senderNumber    String?
  isFromMe        Boolean   @default(false)
  message         String
  messageHash     String?
  messageType     String    @default("TEXT") // MessageType
  ingestionStatus String    @default("NEW")  // IngestionStatus
  receivedAt      DateTime
  districtId      String?
  district        District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  dsdReport       DsdReport?

  @@index([receivedAt])
  @@index([ingestionStatus])
  @@index([messageHash])
  @@index([receivedAt, ingestionStatus])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // AuditAction
  entity     String
  entityId   String
  beforeJson String?
  afterJson  String?
  userId     String?
  userName   String   @default("Operator")
  timestamp  DateTime @default(now())

  @@index([timestamp])
  @@index([action])
  @@index([entity])
  @@index([entityId])
}

model SystemNotification {
  id        String   @id @default(uuid())
  type      String   // NotificationType
  category  String   // NotificationCategory
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@index([category])
  @@index([type])
}
